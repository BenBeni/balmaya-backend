# Container image deployed by GitHub Actions.
APP_IMAGE=ghcr.io/YOUR_GITHUB_ORG_OR_USER/balmaya-backend:latest

# Public hostnames used by Caddy/Keycloak.
APP_HOST=api.example.com
KEYCLOAK_HOSTNAME=keycloak.example.com

# Backend PostgreSQL credentials.
BACKEND_DB_NAME=balmaya
BACKEND_DB_USER=balmaya_app
BACKEND_DB_PASSWORD=replace_me

# Keycloak PostgreSQL credentials.
KC_DB_NAME=keycloak
KC_DB_USER=keycloak_app
KC_DB_PASSWORD=replace_me

# Keycloak bootstrap admin credentials.
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=replace_me

# Keycloak app integration settings.
KEYCLOAK_REALM=balmaya
KEYCLOAK_CLIENTAPP_CLIENT_ID=balmayaclient
KEYCLOAK_CLIENTAPP_CLIENT_SECRET=replace_me
KEYCLOAK_CLIENT_ID=balmaya
KEYCLOAK_CLIENT_SECRET=replace_me

# Local time zone for cron/containers.
TZ=UTC
